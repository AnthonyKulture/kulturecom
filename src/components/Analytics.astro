---
// Google Analytics 4 (gtag.js) — loaded site-wide from BaseLayout <head>.
//
// RGPD/CNIL: this currently fires unconditionally. For full compliance it
// should be gated behind a consent banner (Consent Mode v2: default `denied`,
// then `gtag('consent','update',…)` once the visitor accepts). See ACTION-PLAN.md.
//
// is:inline keeps Astro from bundling/hoisting these — gtag must run as-is.
---
<script async src="https://www.googletagmanager.com/gtag/js?id=G-W64W3JKY43" is:inline></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', 'G-W64W3JKY43');
</script>
