---
// In-article highlight box for key points / takeaways. Usage in .mdx:
//   <Callout title="À retenir">…markdown…</Callout>
// The slotted content keeps prose styling (it's NOT `.not-prose`), so lists and
// emphasis render normally inside.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<aside
  class="my-10 border-l-2 border-[var(--color-accent)] bg-[var(--color-bg-shade)] px-5 py-5 sm:px-6"
>
  {
    title && (
      <p class="font-mono mb-2 text-[11px] uppercase tracking-[0.18em] text-[var(--color-accent)]">
        {title}
      </p>
    )
  }
  <div class="callout-body text-[clamp(14px,1.05vw,16px)] leading-[1.6] text-[var(--color-ink)]">
    <slot />
  </div>
</aside>

<style>
  /* Tighten spacing for content slotted inside the callout. */
  .callout-body :global(p) {
    margin: 0;
  }
  .callout-body :global(p + p) {
    margin-top: 0.75rem;
  }
  .callout-body :global(ul) {
    margin: 0.25rem 0 0;
    padding-left: 1.25rem;
    list-style: disc;
  }
</style>
