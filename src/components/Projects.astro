---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import { getProjects } from "~/lib/projects-data";
import Eyebrow from "~/components/Eyebrow.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

// Shared with ProjectsMobile.astro via src/lib/projects-data.ts (single source
// of truth). Display order: Surly → Eden Rock → Sun Beach House → Royal Yacht → Vaulk.
const projects = getProjects(t);
---

<section
  data-projects
  class="relative flex h-full min-h-[100dvh] flex-col overflow-hidden bg-[var(--color-bg)] px-4 sm:px-6 md:px-10"
  aria-label={t.projects.eyebrow}
>
  <div class="mx-auto flex w-full max-w-[var(--container-wide)] flex-1 min-h-0 flex-col pt-[clamp(40px,6vh,72px)] pb-[clamp(20px,3vh,40px)]">

    <!-- Header : eyebrow + title + count -->
    <header class="flex items-end justify-between gap-6 shrink-0">
      <div>
        <Eyebrow label={t.projects.eyebrow} class="mb-3" />
        <h2 class="font-display text-[clamp(24px,4vw,56px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
          <span class="block">{t.projects["title.line1"]}</span>
          <span class="block">{t.projects["title.line2"]}</span>
        </h2>
      </div>
      <p class="font-mono shrink-0 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
        05 / {t.projects["count.label"]}
      </p>
    </header>

    <!-- 5 equal cards in a horizontal row -->
    <div class="mt-[clamp(20px,3vh,40px)] grid grid-cols-5 gap-3 md:gap-5 flex-1 min-h-0">
      {
        projects.map((p) => (
          <article data-project-card class="group flex flex-col min-h-0">
            <div class="relative flex-1 min-h-0 overflow-hidden">
              {p.video ? (
                <video
                  src={p.video}
                  poster={p.image}
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  aria-label={`${p.title} — ${p.tag}`}
                  class="absolute inset-0 block h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                />
              ) : (
                <img
                  src={p.image}
                  alt={`${p.title} — ${p.tag}`}
                  width="500"
                  height="700"
                  loading="lazy"
                  class="absolute inset-0 block h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                />
              )}
              <span class="font-mono absolute left-2 top-2 rounded-sm bg-[var(--color-bg)]/90 px-1.5 py-0.5 text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink)]">
                {p.num}
              </span>

              {/* Result stamp — bottom-right, dark ink with accent dot. The
                  metric is the visual proof : it stays visible at all times. */}
              <div class="font-mono absolute bottom-2 right-2 inline-flex items-center gap-1.5 bg-[var(--color-ink)] px-2 py-1 text-[9px] uppercase leading-tight tracking-[0.18em] text-[var(--color-bg)] max-w-[calc(100%-1rem)]">
                <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] shrink-0"></span>
                <span class="truncate">{p.metric}</span>
              </div>

              {/* Hover overlay — problem + summary revealed on hover (desktop only).
                  Cream backdrop, ink text. Pure CSS transition, no JS. */}
              <div class="pointer-events-none absolute inset-0 flex flex-col justify-end gap-2 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/95 to-transparent p-3 opacity-0 transition-opacity duration-300 ease-out group-hover:opacity-100">
                <p class="font-serif-italic text-[clamp(11px,0.9vw,14px)] leading-snug text-[var(--color-ink)]">
                  {p.problem}
                </p>
                <p class="text-[clamp(10px,0.8vw,12px)] leading-snug text-[var(--color-ink-muted)]">
                  {p.summary}
                </p>
              </div>
            </div>
            {/* Fixed-height meta block : 3 single-line elements with line-clamp-1
                guarantee the bottom text block has identical height across all
                cards, so the flex-1 image area above also matches. */}
            <div class="mt-2 flex shrink-0 flex-col gap-0.5 min-h-[60px]">
              <h3 class="font-sans text-[clamp(12px,1.05vw,15px)] font-medium leading-snug tracking-normal text-[var(--color-ink)] line-clamp-1">
                {p.title}
              </h3>
              <p class="text-[clamp(10px,0.8vw,12px)] leading-snug text-[var(--color-ink-muted)] line-clamp-1">
                {p.client}
              </p>
              <span class="font-mono mt-0.5 text-[9px] uppercase leading-snug tracking-[0.18em] text-[var(--color-ink-subtle)] line-clamp-1">
                {p.tag}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
