---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import Eyebrow from "~/components/Eyebrow.astro";

interface Props {
  lang: Lang;
  chapterKey: "about2";
}

const { lang, chapterKey } = Astro.props;
const t = ui[lang];
const chapter = t[chapterKey] as Record<string, string>;
// About 2 is now TRANSPARENT: the calm Promesse photo + its scrim live on the
// fixed [data-promesse-photo] layer behind the screen-stack (the cylinder
// cross-dissolves into it). This section only carries the cream text, which
// writes in over that held photo once the stack pins (driven by about-scroll.ts).
// The Eyebrow uses `variant="dark"` to harmonize with the cream-on-ink palette.
---

<section
  data-about-chapter
  data-about-chapter-key={chapterKey}
  data-surface="dark"
  class="relative flex h-full min-h-[100dvh] flex-col justify-between overflow-hidden text-[var(--color-ink)] [text-shadow:0_1px_24px_rgba(0,0,0,0.55)] px-4 pt-10 pb-10 sm:px-6 sm:pt-14 sm:pb-14 md:px-12 md:pt-16 md:pb-16"
  aria-label={chapter.eyebrow}
>
  {/* Contrast comes from (a) the soft gradient scrim baked into the [data-promesse-photo] layer
      and (b) the inherited text-shadow on this section — so the image keeps no flat dark filter. */}

  <!-- TOP : eyebrow left + accent echo right -->
  <header data-about2-reveal class="relative z-10 flex items-start justify-between gap-4 shrink-0">
    <Eyebrow label={chapter.eyebrow} variant="dark" />
    <p class="font-mono text-right text-[11px] uppercase tracking-[0.18em] opacity-60">
      — {chapter.accent}
    </p>
  </header>

  <!-- CENTER : editorial prose + mouse-click CTA -->
  <div data-about2-reveal class="relative z-10 flex flex-1 items-center">
    <div class="w-full max-w-[36rem] sm:max-w-[44rem] md:max-w-[56rem]">
      <p
        data-about-chapter-line
        class="font-serif-italic text-[clamp(22px,3.6vw,56px)] leading-[1.15] tracking-normal"
      >
        {chapter["body.lead"]}
      </p>
      {/* Clickable CTA wraps the entire "Ça commence par un clic" line —
          smooth-scrolls to the Contact reveal when activated. about-scroll.ts
          attaches the click handler at init and computes the target scroll
          position from the pinned-timeline math. */}
      <button
        type="button"
        data-about-chapter-line
        data-about-chapter-cta
        aria-label={lang === "en" ? "Continue to contact" : "Continuer vers le contact"}
        class="group font-display mt-8 flex flex-wrap items-end gap-x-[0.35em] gap-y-2 bg-transparent p-0 text-left text-[clamp(20px,2.8vw,44px)] uppercase leading-[1] text-[inherit] cursor-pointer transition-colors duration-200 hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--color-accent)] sm:mt-10 md:mt-12"
      >
        <span>{chapter["body.trail"]}</span>
        <span class="inline-flex items-end gap-[0.3em]">
          <span class="underline decoration-[0.06em] underline-offset-[0.18em]">{chapter["body.cta"]}</span>
          <svg
            role="img"
            aria-hidden="true"
            viewBox="0 0 32 44"
            width="0.85em"
            height="1.15em"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="inline-block translate-y-[0.05em]"
          >
            <!-- click indication: 3 small radiating lines above -->
            <path d="M16 1 L16 4" />
            <path d="M6 4 L8 6.5" />
            <path d="M26 4 L24 6.5" />
            <!-- mouse body -->
            <rect x="5" y="10" width="22" height="32" rx="11" />
            <!-- top split line (left/right buttons) -->
            <line x1="16" y1="10" x2="16" y2="20" />
            <!-- scroll wheel highlight -->
            <line x1="16" y1="14" x2="16" y2="18" stroke-width="3" />
          </svg>
        </span>
      </button>
    </div>
  </div>

  <!-- BOTTOM : thin rule left + giant accent number right -->
  <div data-about2-reveal class="relative z-10 flex items-end justify-between gap-4 shrink-0">
    <span class="inline-block h-px w-[clamp(40px,8vw,96px)] bg-current opacity-40" aria-hidden="true"></span>
    <span
      class="font-display text-[clamp(80px,16vw,200px)] leading-[0.85] tracking-[-0.04em] opacity-80"
      aria-hidden="true"
      >{chapter.accent}</span
    >
  </div>
</section>
