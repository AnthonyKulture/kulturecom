---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  lang: Lang;
  altLangPath: string;
  altLang: Lang;
}

const { lang, altLangPath, altLang } = Astro.props;
const t = ui[lang];
const aboutHref = lang === "fr" ? "/a-propos/" : "/en/about/";
---

<nav
  class="absolute left-0 right-0 top-0 z-50 flex items-center justify-between px-4 py-4 sm:px-6 md:px-12 md:py-7"
  aria-label="Navigation principale"
>
  <a
    href={lang === "fr" ? "/" : "/en/"}
    class="font-mono text-[12px] lowercase tracking-[-0.01em] text-[var(--color-ink)] no-underline hover:underline underline-offset-4 sm:text-[13px]"
    >{t.nav.brand}</a
  >

  <div class="flex items-center gap-4 sm:gap-6">
    <a
      href={aboutHref}
      class="font-mono hidden text-[12px] uppercase tracking-[0.04em] text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-ink)] sm:inline-block sm:text-[13px]"
      >{t.nav.about}</a
    >
    <a
      href={altLangPath}
      hreflang={altLang}
      class="font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-ink)]"
      >{altLang === "en" ? "EN" : "FR"}</a
    >
    <a
      href={`mailto:${t.footer["contact.email"]}?subject=${encodeURIComponent(t.nav["cta.subject"])}`}
      class="font-mono inline-flex items-center gap-1.5 text-[12px] uppercase tracking-[0.04em] text-[var(--color-ink)] no-underline hover:underline underline-offset-4 sm:text-[13px]"
      ><span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>{t.nav.cta}</a
    >
  </div>
</nav>
