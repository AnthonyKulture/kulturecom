---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = ui[lang].cinematic as Record<string, string>;

// Cinematic cylinder — a FIXED full-viewport WebGL (OGL) stage that NEVER moves,
// plus a tall scroll spacer that drives the scrubbed timeline (src/lib/cinematic-scroll.ts).
// The About above scrolls OFF the stage to reveal it, and the screen-stack below
// scrolls OVER it to cover it — so the cylinder appears and dissolves IN PLACE,
// with no section sliding in/out as a block. The stage sits at z-index:-1 and is
// HIDDEN by default (opacity-0): cinematic-scroll.ts shows it ONLY while the spacer
// is in view, so its black never covers the cream hero (above) or CTA (below). While
// shown, the (opaque, dark) About and screen-stack still paint over it during the
// reveal/cover. The cylinder emerges from / dissolves to black at the two ends so
// those reveal/cover moments are seamless dark-on-dark. Captions fade in/out per
// scroll-quarter; a static <img> fallback stands in when WebGL is skipped.
type CaptionPos = "top" | "center" | "bottom";
const captions: { title: string; desc: string; position: CaptionPos }[] = [
  { title: c["cap1.title"], desc: c["cap1.desc"], position: "top" },
  { title: c["cap2.title"], desc: c["cap2.desc"], position: "center" },
  { title: c["cap3.title"], desc: c["cap3.desc"], position: "center" },
  { title: c["cap4.title"], desc: c["cap4.desc"], position: "bottom" },
];

const getPositionClasses = (position: CaptionPos): string => {
  switch (position) {
    case "top":
      return "top-20 left-1/2 -translate-x-1/2 max-md:top-[25vh]";
    case "bottom":
      return "bottom-20 left-1/2 -translate-x-1/2 max-md:bottom-[12vh] max-md:px-6";
    case "center":
    default:
      return "top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2";
  }
};
---

<section data-cinematic aria-label={c["cap1.title"]}>
  {/* Fixed stage — never moves; revealed/covered by the neighbouring sections. */}
  <div
    data-cinematic-stage
    class="fixed inset-0 overflow-hidden bg-[#0b0b0b] opacity-0"
    style="z-index: -1;"
  >
    {/* Static stand-in revealed by cinematic-scroll.ts when WebGL is skipped. */}
    <img
      data-cinematic-fallback
      src="/hero-slides/eden-rock.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 hidden h-full w-full object-cover opacity-40"
    />
    <canvas data-cinematic-canvas class="absolute inset-0 block h-full w-full"></canvas>

    <div class="pointer-events-none absolute inset-0 z-10 text-[#efe9dc]">
      {
        captions.map((cap, i) => (
          <div
            data-cinematic-caption
            data-cinematic-caption-index={i}
            class:list={[
              "absolute text-center opacity-0 max-md:w-full",
              getPositionClasses(cap.position),
            ]}
          >
            <h2 class="font-serif-italic text-[clamp(40px,7vw,84px)] leading-[0.92]">
              {cap.title}
            </h2>
            {cap.desc && (
              <p class="font-mono mt-3 text-[clamp(13px,1.4vw,18px)] uppercase tracking-[0.18em] opacity-60">
                {cap.desc}
              </p>
            )}
          </div>
        ))
      }
    </div>
  </div>

  {/* Scroll runway (normal flow) between About and the screen-stack — drives the
      scrubbed timeline. Transparent, so the fixed stage shows through it. */}
  <div data-cinematic-spacer aria-hidden="true" class="h-[350svh] md:h-[500svh]"></div>
</section>
