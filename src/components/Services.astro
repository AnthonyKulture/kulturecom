---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import ServicesTrail from "~/components/ServicesTrail";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const items = [
  {
    label: t.services["item1.label"],
    title: t.services["item1.title"],
    body: t.services["item1.body"],
  },
  {
    label: t.services["item2.label"],
    title: t.services["item2.title"],
    body: t.services["item2.body"],
  },
  {
    label: t.services["item3.label"],
    title: t.services["item3.title"],
    body: t.services["item3.body"],
  },
];

// Pre-split titles into per-word spans at SSR. Same pattern as About:
// avoids runtime DOM mutation that would cause a layout reflow before the
// mask-reveal animation starts. .split-word + .split-word-inner CSS classes
// defined in global.css alongside .about-word (shared utility).
const splitTitle = (s: string) =>
  s
    .split(/\s+/)
    .map(
      (w) =>
        `<span class="split-word"><span class="split-word-inner">${w}</span></span>`
    )
    .join(" ");
---

<section
  data-services
  class="relative flex h-full min-h-[100dvh] items-center overflow-hidden bg-[#efe9dc] px-4 sm:px-6 md:px-12"
  aria-label={t.services.eyebrow}
>
  <!-- Image trail effect (mouse-driven, behind text).
       client:media gates the React island + framer-motion + uuid bundle
       (~55 kB gz) to viewports ≥640px AND with a fine pointer (mouse, not
       touch). Mobile + touch-only laptops never hydrate this island.
       The component itself also bails early on mobile via matchMedia,
       so this is belt-and-suspenders for both bundle size and runtime. -->
  <ServicesTrail client:media="(min-width: 640px) and (pointer: fine)" />

  <!-- Scroll progress indicator (top-right) : fills during the Services
       plateau, signaling that the next section (Projects, letter-masked by
       a giant `+`) is about to arrive. The `+` glyph in the ring center
       foreshadows the reveal. -->
  <div
    data-services-progress
    class="pointer-events-none absolute right-4 top-4 z-20 sm:right-6 sm:top-6 md:right-12 md:top-10"
    aria-hidden="true"
  >
    <div class="relative aspect-square w-[clamp(56px,5vw,76px)]">
      <svg viewBox="0 0 100 100" class="block h-full w-full -rotate-90">
        <circle
          cx="50"
          cy="50"
          r="46"
          fill="none"
          stroke="#0b0b0b"
          stroke-opacity="0.15"
          stroke-width="2.5"
        />
        <circle
          data-services-progress-ring
          cx="50"
          cy="50"
          r="46"
          fill="none"
          stroke="var(--color-accent, #c14a1d)"
          stroke-width="3"
          stroke-linecap="square"
          stroke-dasharray="289.027"
          stroke-dashoffset="289.027"
        />
      </svg>
      <span
        class="font-display absolute inset-0 flex items-center justify-center text-[clamp(20px,2.2vw,28px)] leading-none text-[#0b0b0b]"
        >+</span
      >
    </div>
    <p
      class="font-mono mt-2 text-right text-[9px] uppercase tracking-[0.22em] text-[#5a5a5a]"
    >
      Next · 04
    </p>
  </div>

  <div class="relative z-10 mx-auto w-full max-w-[var(--container-wide)]">
    <p
      data-services-line
      class="font-mono mb-6 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[#5a5a5a] sm:mb-10"
    >
      <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
      {t.services.eyebrow}
    </p>

    <h2
      class="font-display text-[clamp(34px,6.2vw,104px)] uppercase leading-[0.95] tracking-[-0.04em] text-[#0b0b0b]"
    >
      <span
        data-services-line
        data-services-h2-line
        class="block"
        set:html={splitTitle(t.services["title.line1"])}
      />
      <span
        data-services-line
        data-services-h2-line
        class="block"
        set:html={splitTitle(t.services["title.line2"])}
      />
    </h2>

    <ul class="mt-10 grid gap-6 sm:mt-14 md:grid-cols-3 md:gap-10 md:mt-20">
      {
        items.map((item, i) => (
          <li
            data-services-line
            data-services-item={i}
            class="relative border-t border-[#d4ccba] pt-4 md:pt-6"
          >
            <span class="font-mono block text-[11px] uppercase tracking-[0.16em] text-[#7a7a7a]">
              {item.label}
            </span>
            <h3
              data-services-item-title={i}
              class="font-sans mt-2 text-[clamp(20px,2.4vw,30px)] font-medium tracking-[-0.02em] text-[#0b0b0b]"
              set:html={splitTitle(item.title)}
            />
            <p
              data-services-item-body={i}
              class="mt-3 max-w-[42ch] text-[clamp(14px,1vw,16px)] leading-[1.55] text-[#3a3a3a]"
            >
              {item.body}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
