---
import type { Lang } from "~/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Brand mark — same dual-typo as Nav.astro: "Anthony" in serif italic glued
// to "PROFIT" in display caps. Letters are SSR-split into `.preloader-letter`
// spans so the JS can stagger their opacity reveal (typewriter phase, which
// only runs AFTER the loading bar reaches 100% and fonts are ready).
const SERIF_LETTERS = Array.from("Anthony");
const DISPLAY_LETTERS = Array.from("PROFIT");
---

<div
  id="preloader"
  class="preloader fixed inset-0 z-[100] overflow-hidden bg-[var(--color-bg)]"
  aria-busy="true"
  aria-label={lang === "fr" ? "Chargement" : "Loading"}
  role="status"
>
  {/* Center brand mark — MASKED (letters opacity 0) during loading, then typed
      in and morphed to the Nav logo. Same dual-typo + cream source +
      mix-blend-difference as Nav.astro so the morph hand-off is color-perfect.
      `transform-origin: 0 0` + `will-change: transform` enable the FLIP morph. */}
  <div class="absolute inset-0 flex items-center justify-center px-4 pointer-events-none">
    <div
      data-preloader-name
      class="inline-flex items-baseline gap-0 whitespace-nowrap leading-none text-[clamp(40px,11vw,144px)] text-[var(--color-bg)] mix-blend-difference"
      style="transform-origin: 0 0; will-change: transform;"
    ><span class="font-serif-italic">{SERIF_LETTERS.map((c) => (<span class="preloader-letter">{c}</span>))}</span><span class="font-display tracking-[-0.02em]">{DISPLAY_LETTERS.map((c) => (<span class="preloader-letter">{c}</span>))}</span></div>
  </div>

  {/* Loading UI — architectural: top-left label, bottom-right %, full-width
      bottom bar. The JS drives the bar (scaleX) + percent from real asset
      progress. Fades out as one unit when loading completes, before the
      typewriter. */}
  <div data-preloader-loading class="absolute inset-0 pointer-events-none">
    <!-- Top-left label -->
    <span
      class="font-mono absolute left-4 top-4 text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)] sm:left-6 sm:top-6 sm:text-[11px] md:left-12 md:top-12"
    >{lang === "fr" ? "Chargement" : "Loading"}</span>

    <!-- Bottom-right percentage readout -->
    <span
      data-preloader-percent
      class="font-mono absolute bottom-5 right-4 text-[11px] tabular-nums tracking-[0.12em] text-[var(--color-ink)] sm:right-6 sm:text-[12px] md:right-12"
      aria-hidden="true"
    >0%</span>

    <!-- Full-width bottom progress bar (track + scaleX fill) -->
    <div
      class="absolute inset-x-0 bottom-0 h-[6px] bg-[var(--color-border)]"
      aria-hidden="true"
    >
      <span
        data-preloader-bar
        class="block h-full w-full origin-left bg-[var(--color-ink)] will-change-transform"
        style="transform: scaleX(0);"
      ></span>
    </div>
  </div>
</div>

<script>
  import { initPreloader } from "~/lib/preloader";
  initPreloader();
</script>
