---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

// About manifesto — 5 statements, each a full-bleed text block in normal flow
// that reveals on scroll (per-word blur cascade, driven by GSAP ScrollTrigger
// in `src/lib/about-reveal.ts`).
//
// The PORTRAIT is no longer part of these sections: it's a FIXED element
// (AboutPortrait.astro + src/lib/about-portrait.ts) rendered as a sibling of
// this block, held on the side (desktop) / top banner (mobile) while these
// statements scroll past it. So every statement here is a uniform LEFT-column
// text block — on desktop `md:pr-[42vw]` reserves the right side for the
// pinned portrait; on mobile the block is full-width and the rising text
// dissolves under the top banner.
//
// Each TITLE word is wrapped in an `.about-reveal-word` span and each
// DESCRIPTION word in an `.about-body-word` span (SSR split) so GSAP can
// stagger opacity/transform/filter per word. `<em>` phrases become serif
// italic per word via the `--italic` modifier.
const wrapWords = (s: string): string =>
  s
    .split(/\s+/)
    .filter(Boolean)
    .map((w) => `<span class="about-reveal-word">${w}</span>`)
    .join(" ");

// Per-word reveal for the description, with <em>...</em> tokens preserved
// as serif italic on a per-word basis. We split the input on the <em>
// boundary, then for each segment whitespace-split and wrap every word in
// a `.about-body-word` span — em-segments get an extra `--italic` modifier
// so they render in Instrument Serif italic at 1.08em. Safe against
// malformed input : if no <em> tags are present, the entire string is
// treated as a single non-italic segment and every word still gets wrapped.
const wrapBodyWords = (s: string): string => {
  // Split on <em>…</em> tokens AND <br> tags. <em> segments get italic
  // styling per word; <br> is emitted as-is (inline structural break,
  // not wrapped as a "word") so the GSAP cascade skips it but the
  // browser still renders the line break inside the <p>.
  const parts = s.split(/(<em>[\s\S]*?<\/em>|<br\s*\/?>)/g);
  return parts
    .map((part) => {
      if (!part) return "";
      if (/^<br\s*\/?>$/.test(part)) return part;
      const emMatch = part.match(/^<em>([\s\S]*?)<\/em>$/);
      const text = emMatch ? emMatch[1] : part;
      const cls = emMatch
        ? "about-body-word about-body-word--italic"
        : "about-body-word";
      return text
        .split(/\s+/)
        .filter(Boolean)
        .map((w) => `<span class="${cls}">${w}</span>`)
        .join(" ");
    })
    .filter(Boolean)
    .join(" ");
};

const tAbout = t.about as Record<string, string>;
// Strip the `<em>` markup for the aria-label (screen-readers hear the rendered
// text; the inline <em> still renders for sighted users).
const stripEm = (s: string): string => s.replace(/<\/?em>/g, "");
const chapters = ([1, 2, 3, 4] as const).map((n) => ({
  index: n - 1,
  plainTitle: tAbout[`item${n}.title`],
  titleHtml: wrapWords(tAbout[`item${n}.title`]),
  descHtml: wrapBodyWords(tAbout[`item${n}.desc`]),
  descPlain: stripEm(tAbout[`item${n}.desc`]),
}));
---

<div class="relative bg-[#0b0b0b] text-[#efe9dc]">
  {chapters.map((chapter) => {
    // The intro (statement 0) keeps the original, longer copy, so it gets a
    // little more height than the condensed statements that follow. Short
    // sections keep the statements close together so one leaves the top as
    // the next enters the bottom (see about-reveal.ts for the timing).
    const isIntro = chapter.index === 0;
    return (
      <section
        data-about-chapter-section
        data-about-chapter-index={chapter.index}
        class:list={[
          "relative overflow-hidden",
          isIntro ? "min-h-[56dvh]" : "min-h-[46dvh]",
        ]}
        aria-label={chapter.plainTitle}
      >
        {/* TEXT CONTENT — vertically centered so the parallax + reveal carries
            it up through the viewport: it appears low (from the bottom edge),
            peaks at center, and exits at the top (dissolving under the top
            portrait banner on mobile), one statement at a time. Left column;
            the right side is reserved for the fixed portrait on desktop. */}
        <div
          data-about-chapter-content
          class:list={[
            "relative w-full flex flex-col justify-center px-6 md:pl-12 md:pr-[42vw]",
            isIntro ? "min-h-[56dvh]" : "min-h-[46dvh]",
          ]}
        >
          <h3
            data-about-chapter-title
            class="font-display block text-left text-[clamp(16px,2.2vw,32px)] uppercase leading-[1.05] tracking-[-0.03em]"
            set:html={chapter.titleHtml}
          />
          <p
            data-about-chapter-body
            class="about-body-reveal font-sans text-left text-[clamp(19px,2.1vw,28px)] leading-[1.5] text-[#efe9dc]/85 max-w-[62ch] mt-8 md:mt-12"
            set:html={chapter.descHtml}
          />
        </div>
      </section>
    );
  })}
</div>
