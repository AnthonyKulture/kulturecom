---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

// About — three service teasers: Direction artistique & design / Développement
// web sur-mesure / SEO & GEO technique. Each is a full-bleed text block in
// normal flow that reveals on scroll (GSAP ScrollTrigger, `src/lib/about-reveal.ts`),
// shown as a large serif-italic title prefixed by a mono index (01/02/03).
// (`data-about-variant` still drives the styling; the personal intro block that
// used the brutalist display treatment was removed.)
//
// The PORTRAIT is a FIXED sibling element (AboutPortrait.astro +
// src/lib/about-portrait.ts), held on the side (desktop) / top banner (mobile)
// while these blocks scroll past it. On desktop `md:pr-[42vw]` reserves the
// right side for it; on mobile the block is full-width and the rising text
// dissolves under the top banner. The portrait SWAPS to a second image (blur
// in/out) as the services arrive (about-portrait.ts).
//
// Each TITLE word is wrapped in an `.about-reveal-word` span and each
// DESCRIPTION word in an `.about-body-word` span (SSR split) so GSAP can
// stagger opacity/transform per word; the blur lives on the title/body
// CONTAINER. `<em>` phrases become serif italic per word via the `--italic`
// modifier. Service titles also carry a leading `.about-service-num` span.
const wrapWords = (s: string): string => {
  // Split on <em>…</em> tokens so emphasised words render in serif italic
  // (`--italic` modifier) while the rest follow the title's base font. On the
  // intro this produces the two-font "fusion" — brutalist display UPPERCASE
  // with Instrument Serif italic accents. No <em> ⇒ every word is a plain
  // `.about-reveal-word`.
  const parts = s.split(/(<em>[\s\S]*?<\/em>)/g);
  return parts
    .map((part) => {
      if (!part) return "";
      const emMatch = part.match(/^<em>([\s\S]*?)<\/em>$/);
      const text = emMatch ? emMatch[1] : part;
      const cls = emMatch
        ? "about-reveal-word about-reveal-word--italic"
        : "about-reveal-word";
      return text
        .split(/\s+/)
        .filter(Boolean)
        .map((w) => `<span class="${cls}">${w}</span>`)
        .join(" ");
    })
    .filter(Boolean)
    .join(" ");
};

// Per-word reveal for the description, with <em>...</em> tokens preserved
// as serif italic on a per-word basis. We split the input on the <em>
// boundary, then for each segment whitespace-split and wrap every word in
// a `.about-body-word` span — em-segments get an extra `--italic` modifier
// so they render in Instrument Serif italic at 1.08em. Safe against
// malformed input : if no <em> tags are present, the entire string is
// treated as a single non-italic segment and every word still gets wrapped.
const wrapBodyWords = (s: string): string => {
  // Split on <em>…</em> tokens AND <br> tags. <em> segments get italic
  // styling per word; <br> is emitted as-is (inline structural break,
  // not wrapped as a "word") so the GSAP cascade skips it but the
  // browser still renders the line break inside the <p>.
  const parts = s.split(/(<em>[\s\S]*?<\/em>|<br\s*\/?>)/g);
  return parts
    .map((part) => {
      if (!part) return "";
      if (/^<br\s*\/?>$/.test(part)) return part;
      const emMatch = part.match(/^<em>([\s\S]*?)<\/em>$/);
      const text = emMatch ? emMatch[1] : part;
      const cls = emMatch
        ? "about-body-word about-body-word--italic"
        : "about-body-word";
      return text
        .split(/\s+/)
        .filter(Boolean)
        .map((w) => `<span class="${cls}">${w}</span>`)
        .join(" ");
    })
    .filter(Boolean)
    .join(" ");
};

const tAbout = t.about as Record<string, string>;

type Block = {
  variant: "intro" | "service";
  plainTitle: string;
  titleHtml: string;
  descHtml: string;
};

// The About section is now the three service teasers only — the personal intro
// block was removed. Same scroll-reveal sequence, but
// a serif-italic title prefixed by a mono index (01/02/03), echoing the
// dedicated Services section. The index span is baked into the title HTML so it
// rides the container blur reveal (it is NOT an `.about-reveal-word`, so it sits
// at opacity 1 and sharpens with the block instead of cascading word-by-word).
const services: Block[] = ([1, 2, 3] as const).map((n) => ({
  variant: "service",
  plainTitle: tAbout[`svc${n}.title`],
  titleHtml:
    `<span class="about-service-num">${tAbout[`svc${n}.num`]}</span>` +
    wrapWords(tAbout[`svc${n}.title`]),
  descHtml: wrapBodyWords(tAbout[`svc${n}.desc`]),
}));

const chapters: Block[] = services;
---

<div class="relative bg-[#0b0b0b] text-[#efe9dc]">
  {chapters.map((chapter) => {
    // Each service is sized to its own content with EQUAL vertical padding, so
    // the gap between the three teasers is constant. (Fixed-height slots with
    // centred content made the gaps look uneven because the copy lengths
    // differ.) `isIntro` is kept only for the title/body styling branches below
    // — every block is a service now.
    const isIntro = chapter.variant === "intro";
    return (
      <section
        data-about-chapter-section
        data-about-variant={chapter.variant}
        class="relative overflow-hidden"
        aria-label={chapter.plainTitle}
      >
        {/* TEXT CONTENT — vertically centered so the parallax + reveal carries
            it up through the viewport: it appears low (from the bottom edge),
            peaks at center, and exits at the top (dissolving under the top
            portrait banner on mobile), one statement at a time. Left column;
            the right side is reserved for the fixed portrait on desktop. */}
        <div
          data-about-chapter-content
          class="relative w-full flex flex-col px-6 py-[11dvh] md:pl-12 md:pr-[42vw] md:py-[13dvh]"
        >
          <h3
            data-about-chapter-title
            class:list={[
              "block text-left",
              isIntro
                ? "font-display text-[clamp(28px,4.6vw,60px)] uppercase leading-[1.02] tracking-[-0.03em]"
                : "font-serif-italic text-[clamp(42px,7.5vw,92px)] leading-[0.92] tracking-[-0.015em]",
            ]}
            set:html={chapter.titleHtml}
          />
          <p
            data-about-chapter-body
            class:list={[
              "about-body-reveal font-sans text-left",
              isIntro
                ? "text-[clamp(19px,2.1vw,28px)] leading-[1.5] text-[#efe9dc]/85 max-w-[62ch] mt-8 md:mt-12"
                : "text-[clamp(15px,1.5vw,19px)] leading-[1.5] text-[#efe9dc]/55 max-w-[46ch] mt-4 md:mt-6",
            ]}
            set:html={chapter.descHtml}
          />
        </div>
      </section>
    );
  })}
</div>
