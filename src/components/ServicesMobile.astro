---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import { splitTitle } from "~/lib/text-split";
import Eyebrow from "~/components/Eyebrow.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const items = [
  {
    label: t.services["item1.label"],
    title: t.services["item1.title"],
    body: t.services["item1.body"],
  },
  {
    label: t.services["item2.label"],
    title: t.services["item2.title"],
    body: t.services["item2.body"],
  },
  {
    label: t.services["item3.label"],
    title: t.services["item3.title"],
    body: t.services["item3.body"],
  },
];

// Per-word SSR splitter shared via `src/lib/text-split.ts`.

const total = items.length;
const pad = (n: number) => String(n).padStart(2, "0");
---

<section
  data-services-mobile-panel
  class="relative h-full min-h-[100dvh] overflow-hidden bg-[#efe9dc]"
  aria-label={t.services.eyebrow}
>
  {items.map((item, i) => (
    <article
      data-axis-card={i}
      data-axis-panel={i}
      class="absolute inset-0"
      style={`opacity: ${i === 0 ? 1 : 0}; z-index: ${30 - i * 10};`}
    >
      {/* TOP — eyebrow left + count right (absolute, top-positioned below
          the fixed Nav so it doesn't collide with the brand logo). */}
      <header
        data-axis-panel-header={i}
        class="absolute left-5 right-5 top-24 z-10 flex items-center justify-between"
      >
        <Eyebrow label={t.services.eyebrow} />
        <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#7a7a7a]">
          {pad(i + 1)} / {pad(total)}
        </p>
      </header>

      {/* GIANT NUMBER — anchored to the right edge, vertically centered.
          Dominates the right column; the digit may bleed slightly off the
          right edge for the brutalist "too big to contain" feel. */}
      <span
        data-axis-panel-label={i}
        class="font-display pointer-events-none absolute right-[-2vw] top-1/2 block -translate-y-1/2 text-[clamp(280px,80vw,420px)] leading-[0.78] tracking-[-0.06em] text-[#0b0b0b]"
      >
        {item.label}
      </span>

      {/* BOTTOM CONTENT — title + body stacked, left-aligned within the
          left column. max-w-[26ch] keeps the column narrow so it never
          collides visually with the right-anchored number. */}
      <div class="absolute bottom-24 left-5 right-5 z-10 max-w-[26ch]">
        <h3
          data-axis-card-title={i}
          class="font-sans text-[clamp(24px,7vw,36px)] font-semibold leading-[1.05] tracking-[-0.025em] text-[#0b0b0b]"
          set:html={splitTitle(item.title)}
        />
        <p
          data-axis-card-body={i}
          class="mt-4 text-[14px] leading-[1.55] text-[#3a3a3a]"
        >
          {item.body}
        </p>
      </div>

      {/* FOOTER — accent line left + hint right, pinned at the bottom edge. */}
      <footer
        data-axis-panel-footer={i}
        class="absolute bottom-10 left-5 right-5 z-10 flex items-end justify-between"
      >
        <span class="block h-px w-[clamp(80px,30vw,140px)] bg-[var(--color-accent)]" />
        <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[#7a7a7a]">
          {i < total - 1 ? "↓ suivant" : "↓ projets"}
        </span>
      </footer>
    </article>
  ))}
</section>
