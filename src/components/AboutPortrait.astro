---
// Fixed portrait for the About section — the "sticky image" the service
// statements scroll past. DESKTOP ONLY (hidden on mobile via `hidden md:block`).
//
// Rendered INSIDE <main> but OUTSIDE [data-about-wrapper]: the wrapper carries
// a translateY transform (hero-transition.ts) that would break position:fixed,
// so the portrait must be a sibling. z-[61] paints it over the dark About
// sections (wrapper is z-60) while staying under the nav. GSAP
// (src/lib/about-portrait.ts) fades it IN as the first statement arrives, holds
// it FIXED across every statement, and fades it OUT before the screen-stack —
// all on absolute (docTop) scroll positions. On mobile the section is plain
// full-width scrolling text (no portrait).
---

<div
  data-about-portrait
  aria-hidden="true"
  class="pointer-events-none fixed z-[61] opacity-0 hidden md:block right-0 top-[13vh] h-[74vh] w-[38vw]"
  style="will-change: transform, opacity;"
>
  {/* Single portrait image — no transition. It fades in/out with the container
      (src/lib/about-portrait.ts) and stays fixed while the services scroll past. */}
  <img
    src="/about/anthony-portrait.webp"
    alt=""
    loading="eager"
    decoding="async"
    class="block h-full w-full object-cover rounded-l-[clamp(8rem,25vw,25rem)]"
  />
</div>
