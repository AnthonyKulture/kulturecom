---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import { splitWordsWithDelay } from "~/lib/text-split";
import ServicesTrail from "~/components/ServicesTrail";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

// Carousel slide sources — used by the mobile inline image block in the H1,
// cycled by hero.ts (1 image/sec, see CAROUSEL_INTERVAL).
const slideSources = Array.from({ length: 20 }, (_, i) =>
  `/hero-slides/slide-${String(i + 1).padStart(2, "0")}.webp`
);

// SSR-split the subtitle into per-word .word-animate spans. Each word gets
// an inline animation-delay so the cascade runs in pure CSS once hero.ts
// sets the `data-words-revealed` attribute on the parent <p>. 30 ms step
// keeps the cascade tight (~1.2 s for ~40 words) without feeling rushed.
const subtitleHtml = splitWordsWithDelay(t.hero.subtitle, 30);
---

<section
  data-hero
  class="relative flex min-h-[100svh] flex-col justify-center overflow-hidden px-4 py-20 sm:items-center sm:px-6 md:px-12 md:py-16"
>
  {/* Image-trail mouse follower — same React island as Services. Hydrates
      when the browser is idle (defers ~44KB framer-motion off the LCP),
      bails on mobile + touch internally. Positioned absolute, behind all
      text content (z-0 vs z-10 wrapper). */}
  <ServicesTrail client:idle />
  <!-- ========== MOBILE LAYOUT (< 640px) ========== -->
  {/* Centered title with an inline cycling image between the two halves,
      mirroring the GLD-style hero. No baseline dividers — let the rhythm of
      the type alternation (display caps + italic lowercase) carry the structure. */}
  <div class="mobile-hero relative z-10 block w-full sm:hidden">
    <h1 class="font-display w-full text-center">
      <span
        data-anim-line
        data-anim-line-half="top"
        class="anim-hidden block text-[clamp(16px,4.5vw,24px)]"
        >{t.hero.line1}</span
      >

      <span
        data-anim-line
        data-anim-line-half="top"
        class="anim-hidden block text-[clamp(36px,10vw,52px)]"
        >{t.hero.line2}</span
      >

      <span
        data-anim-line
        data-anim-line-half="top"
        class="anim-hidden font-serif-italic block normal-case leading-[1.0] tracking-normal text-[clamp(28px,7.5vw,40px)]"
        >{t.hero.line3}</span
      >

      {/* Inline mobile carousel — centered between the two halves of the H1.
          One image per second (CAROUSEL_INTERVAL in hero.ts). */}
      <span
        data-anim-figure
        class="anim-hidden my-2 block w-full"
      >
        <span class="mx-auto block aspect-square w-[clamp(120px,38vw,180px)] overflow-hidden bg-[var(--color-ink)]">
          <img
            data-carousel-img-mobile
            src={slideSources[0]}
            alt="Anthony Profit — sélection projets freelance"
            width="500"
            height="500"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="block h-full w-full object-cover"
          />
        </span>
      </span>

      <span
        data-anim-line
        data-anim-line-half="bottom"
        class="anim-hidden block text-[clamp(34px,9vw,48px)]"
        >{t.hero.line4}</span
      >

      <span
        data-anim-line
        data-anim-line-half="bottom"
        class="anim-hidden font-serif-italic block normal-case leading-[1.0] tracking-normal text-[clamp(24px,6.5vw,32px)]"
        >{t.hero.line5}</span
      >
    </h1>
  </div>

  <!-- ========== TABLET / DESKTOP LAYOUT (≥ 640px) ==========
       NOTE: This visual variant is a <div> (not <h1>) to avoid having two H1
       tags in the rendered HTML. The mobile <h1> above is the canonical SEO
       heading (Google indexes mobile-first). Desktop screen readers still get
       the page heading via the mobile <h1> which is in the DOM regardless of
       viewport — only its visual display is gated by `sm:hidden`. -->
  {/* Desktop title — 5 lines stacked, no inline carousel break.
      The ServicesTrail mouse-follower provides the visual interest behind. */}
  <div
    data-hero-desktop-title
    role="presentation"
    class="font-display relative z-10 hidden w-full max-w-[var(--container-wide)] sm:mx-auto sm:block sm:text-center"
  >
    <span
      data-anim-line
      data-anim-line-half="top"
      class="anim-hidden block text-[clamp(20px,3.5vw,44px)]"
      >{t.hero.line1}</span
    >
    <span
      data-anim-line
      data-anim-line-half="top"
      class="anim-hidden block text-[clamp(40px,7vw,108px)]"
      >{t.hero.line2}</span
    >
    <span
      data-anim-line
      data-anim-line-half="top"
      class="anim-hidden font-serif-italic block normal-case leading-[1.05] tracking-normal text-[clamp(32px,5.5vw,84px)]"
      >{t.hero.line3}</span
    >
    <span
      data-anim-line
      data-anim-line-half="bottom"
      class="anim-hidden block text-[clamp(40px,7vw,108px)]"
      >{t.hero.line4}</span
    >
    <span
      data-anim-line
      data-anim-line-half="bottom"
      class="anim-hidden font-serif-italic block normal-case leading-[1.05] tracking-normal text-[clamp(28px,5vw,72px)]"
      >{t.hero.line5}</span
    >
  </div>

  {/* Subtitle — single mixed positioning + offer paragraph, visible on
      both viewports. Centered. Each word is a .word-animate span (SSR
      via splitWordsWithDelay) that runs the blur-cascade reveal once
      hero.ts sets `data-words-revealed` on the parent. No anim-hidden
      class on the <p> itself — visibility is per-word. */}
  <p
    data-hero-subtitle
    class="font-sans relative z-10 mx-auto mt-6 max-w-[clamp(20rem,92vw,36rem)] text-balance text-center text-[clamp(15px,1.8vw,22px)] leading-[1.45] text-[var(--color-ink-muted)] sm:mt-8 sm:max-w-[clamp(24rem,60vw,50rem)] md:mt-10"
    set:html={subtitleHtml}
  />

  <!-- Side italic label — hidden on mobile, original left placement on md+ -->
  <span
    data-anim-inline
    class="anim-hidden font-serif-italic absolute top-1/2 z-10 hidden -translate-y-1/2 text-[clamp(13px,1.2vw,18px)] text-[var(--color-ink)] md:left-8 md:block lg:left-12"
    >{t.hero["label.side"]}</span
  >

  {/* Scroll-down hint — small label + thin vertical track with a 16px
      segment that slides from top to bottom in a loop. Visually suggests
      "scroll down" without being noisy. Decorative (aria-hidden) since
      the scroll affordance is already conveyed by the page structure. */}
  <div
    data-anim-inline
    data-hero-scroll
    class="anim-hidden absolute bottom-6 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 sm:bottom-8 sm:gap-3"
    aria-hidden="true"
  >
    <span
      class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)] sm:text-[11px]"
      >{t.hero["label.scroll"]}</span
    >
    <span class="hero-scroll-bar relative block h-8 w-px overflow-hidden bg-[color-mix(in_srgb,var(--color-ink)_15%,transparent)] sm:h-12">
      <span class="hero-scroll-bar__progress absolute left-0 top-0 h-4 w-full bg-[var(--color-ink)]"></span>
    </span>
  </div>

  {/* Carousel sources JSON — consumed by hero.ts to cycle the
      [data-carousel-img-mobile] image in the H1 every 1s. */}
  <script
    type="application/json"
    data-carousel-sources
    is:inline
    set:html={JSON.stringify(slideSources)}
  />
</section>

<script>
  import { initHero } from "~/lib/hero";
  initHero();
</script>
