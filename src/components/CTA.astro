---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const mailtoHref = `mailto:${t.cta["email.value"]}?subject=${encodeURIComponent(t.cta.subject)}`;

// WhatsApp deep link: digits only, country code first (no leading +).
// `wa.me` resolves on both web and mobile apps. Pre-filled message is
// urlencoded; users see and can edit before sending.
const whatsappNumber = "33660501682";
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(t.cta["whatsapp.message"])}`;
---

<section
  data-cta
  class="relative flex min-h-[100dvh] flex-col justify-center overflow-hidden bg-[#efe9dc] text-[#0b0b0b] px-4 py-20 sm:px-6 md:px-12"
  aria-label={t.cta.eyebrow}
>
  <div class="mx-auto w-full max-w-[var(--container-wide)]">
    <!-- Eyebrow -->
    <p
      class="font-mono mb-8 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[#5a5a5a] sm:mb-12"
    >
      <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
      {t.cta.eyebrow}
    </p>

    <!-- Display title — brutalist 2 lines, reasonable size -->
    <h2
      class="font-display text-[clamp(36px,7vw,96px)] uppercase leading-[0.95] tracking-[-0.04em] text-[#0b0b0b]"
    >
      <span class="block">{t.cta["title.line1"]}</span>
      <span class="block">{t.cta["title.line2"]}</span>
    </h2>

    <!-- 2 contact actions — Email + WhatsApp, label + value in each card.
         Same brutalist treatment, side by side on sm+, stacked on mobile. -->
    <div
      class="mt-10 grid gap-3 sm:mt-16 sm:grid-cols-2 sm:gap-5 max-w-[var(--container-wide)]"
    >
      <a
        href={mailtoHref}
        class="group relative flex items-center justify-between gap-4 bg-[#0b0b0b] px-5 py-5 text-[#efe9dc] no-underline transition-colors duration-200 hover:bg-[var(--color-accent)] sm:px-7 sm:py-6"
      >
        <div class="flex flex-col gap-1">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] opacity-70">
            {t.cta["email.label"]}
          </span>
          <span class="font-sans text-[clamp(15px,1.4vw,20px)] font-medium tracking-[-0.01em]">
            {t.cta["email.value"]}
          </span>
        </div>
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
        >
          <path d="M5 12 H19" />
          <path d="M13 6 L19 12 L13 18" />
        </svg>
      </a>

      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative flex items-center justify-between gap-4 border border-[#0b0b0b] bg-[#efe9dc] px-5 py-5 text-[#0b0b0b] no-underline transition-colors duration-200 hover:bg-[#0b0b0b] hover:text-[#efe9dc] sm:px-7 sm:py-6"
      >
        <div class="flex flex-col gap-1">
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] opacity-70">
            {t.cta["whatsapp.label"]}
          </span>
          <span class="font-sans text-[clamp(15px,1.4vw,20px)] font-medium tracking-[-0.01em]">
            {t.cta["whatsapp.value"]}
          </span>
        </div>
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
        >
          <path d="M5 12 H19" />
          <path d="M13 6 L19 12 L13 18" />
        </svg>
      </a>
    </div>

    <!-- Note -->
    <p
      class="font-mono mt-8 text-[11px] uppercase tracking-[0.18em] text-[#5a5a5a] sm:mt-10"
    >
      {t.cta.note}
    </p>
  </div>
</section>
