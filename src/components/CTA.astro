---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import Eyebrow from "~/components/Eyebrow.astro";

interface Props {
  lang: Lang;
  // h2 on the homepage finale (sits under the page context); h1 on the
  // standalone /contact/ page where this is the main heading. Same classes →
  // identical render, only the semantic tag differs.
  headingLevel?: 1 | 2;
}

const { lang, headingLevel = 2 } = Astro.props;
const t = ui[lang];

const Heading = `h${headingLevel}` as "h1" | "h2";

const mailtoHref = `mailto:${t.cta["email.value"]}?subject=${encodeURIComponent(t.cta.subject)}`;

// WhatsApp deep link: digits only, country code first (no leading +).
// `wa.me` resolves on both web and mobile apps. Pre-filled message is
// urlencoded; users see and can edit before sending.
const whatsappNumber = "33660501682";
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(t.cta["whatsapp.message"])}`;

const projectsHref = lang === "fr" ? "/projets/" : "/en/work/";
---

<section
  id="contact"
  data-cta
  class="relative flex min-h-[100dvh] flex-col justify-center overflow-hidden bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-20 sm:px-6 md:px-12 scroll-mt-16"
  aria-label={t.cta.eyebrow}
>
  <div class="mx-auto w-full max-w-[var(--container-wide)]">
    <!-- Eyebrow -->
    <Eyebrow label={t.cta.eyebrow} class="mb-8 sm:mb-12" />

    <!-- Display title — brutalist 2 lines, reasonable size -->
    <Heading
      class="font-display text-[clamp(36px,7vw,96px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]"
    >
      <span class="block">{t.cta["title.line1"]}</span>
      <span class="block">{t.cta["title.line2"]}</span>
    </Heading>

    <!-- 2 contact actions — Email + WhatsApp, label + value in each card.
         Same brutalist treatment, side by side on sm+, stacked on mobile. -->
    <div
      class="mt-10 grid gap-3 sm:mt-16 sm:grid-cols-2 sm:gap-5 max-w-[var(--container-wide)]"
    >
      <a
        href={mailtoHref}
        class="group relative flex items-center justify-between gap-4 bg-[var(--color-ink)] px-5 py-5 text-[var(--color-bg)] no-underline transition-colors duration-200 hover:bg-[var(--color-accent)] sm:px-7 sm:py-6"
      >
        <div class="flex flex-col gap-1">
          <span class="font-mono text-[10px] uppercase tracking-[0.18em] opacity-70">
            {t.cta["email.label"]}
          </span>
          <span class="font-sans text-[clamp(15px,1.4vw,20px)] font-medium tracking-normal">
            {t.cta["email.value"]}
          </span>
        </div>
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
        >
          <path d="M5 12 H19" />
          <path d="M13 6 L19 12 L13 18" />
        </svg>
      </a>

      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative flex items-center justify-between gap-4 border border-[var(--color-ink)] bg-[var(--color-bg)] px-5 py-5 text-[var(--color-ink)] no-underline transition-colors duration-200 hover:bg-[var(--color-ink)] hover:text-[var(--color-bg)] sm:px-7 sm:py-6"
      >
        <div class="flex flex-col gap-1">
          <span class="font-mono text-[10px] uppercase tracking-[0.18em] opacity-70">
            {t.cta["whatsapp.label"]}
          </span>
          <span class="font-sans text-[clamp(15px,1.4vw,20px)] font-medium tracking-normal">
            {t.cta["whatsapp.value"]}
          </span>
        </div>
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="square"
          class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
        >
          <path d="M5 12 H19" />
          <path d="M13 6 L19 12 L13 18" />
        </svg>
      </a>
    </div>

    <!-- Secondary CTA — route to the projects page -->
    <a
      href={projectsHref}
      class="group mt-8 inline-flex items-center gap-3 border border-[var(--color-ink)] px-5 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink)] no-underline transition-colors duration-200 hover:bg-[var(--color-ink)] hover:text-[var(--color-bg)] sm:mt-10 sm:px-7 sm:py-4"
    >
      {t.cta["projects.label"]}
      <svg
        aria-hidden="true"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="square"
        class="shrink-0 transition-transform duration-300 ease-out group-hover:translate-x-1"
      >
        <path d="M5 12 H19" />
        <path d="M13 6 L19 12 L13 18" />
      </svg>
    </a>
  </div>
</section>
