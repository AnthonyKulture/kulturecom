---
/**
 * Section eyebrow — mono uppercase label + short accent line.
 *
 * Used at the top of every major section (About, Services, Projects, CTA,
 * AboutChapter) for the same brutalist editorial micro-pattern. The
 * `variant` prop swaps the rendering between light sections (cream bg with
 * terracotta accent line) and dark sections (inverted: current color, lower
 * opacity). Pass any extra wrapper classes (margins, alignment) via `class`.
 */
interface Props {
  label: string;
  variant?: "light" | "dark";
  class?: string;
  // Allow arbitrary HTML attributes (data-*, aria-*, id) to be forwarded
  // to the underlying <p>, e.g. `data-about-line` for GSAP selectors.
  [key: string]: unknown;
}

const { label, variant = "light", class: className = "", ...rest } = Astro.props;

const baseClasses =
  "font-mono inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em]";

const textClasses =
  variant === "dark"
    ? "opacity-70"
    : "text-[var(--color-ink-muted)]";

const lineClasses =
  variant === "dark"
    ? "inline-block h-px w-6 bg-current opacity-60"
    : "inline-block h-px w-6 bg-[var(--color-accent)]";
---

<p {...rest} class:list={[baseClasses, textClasses, className]}>
  <span aria-hidden="true" class={lineClasses}></span>
  {label}
</p>
