---
import type { Lang } from "~/i18n/ui";
import { ui } from "~/i18n/ui";
import type { ServiceId } from "~/lib/service-pages";
import { getServicePage } from "~/lib/service-pages";
import { getCaseStudy, caseStudyPath } from "~/lib/case-studies";
import CTA from "~/components/CTA.astro";

interface Props {
  lang: Lang;
  id: ServiceId;
}

const { lang, id } = Astro.props;
const t = ui[lang];
const sp = getServicePage(id, lang);
if (!sp) throw new Error(`Unknown service page id: ${id}`);

const c = sp.content;
const isFr = lang === "fr";
const pathname = sp.path[lang];
const canonical = new URL(pathname, Astro.site).toString();
const homeUrl = new URL(isFr ? "/" : "/en/", Astro.site).toString();

// Resolve the featured case studies (proof).
const proof = sp.proofSlugs
  .map((slug) => getCaseStudy(t, slug))
  .filter((x): x is NonNullable<typeof x> => x !== null);

const labels = isFr
  ? { breadcrumb: "Fil d'Ariane", availability: "Disponibilité Q4 2026 · Nice / Côte d'Azur · France" }
  : { breadcrumb: "Breadcrumb", availability: "Available Q4 2026 · Nice / French Riviera · France" };

// Structured data — Service + FAQPage + 2-level breadcrumb. Self-contained.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${canonical}#service`,
      "name": c.name,
      "serviceType": c.name,
      "url": canonical,
      "description": c.lead,
      // Reference the global #person entity (emitted by BaseLayout on every
      // page) instead of a blank node, so the Service joins the entity graph
      // that Google's Knowledge Panel + AI citation rely on.
      "provider": { "@id": `${Astro.site}#person` },
      "areaServed": { "@type": "Country", "name": "France" },
      "inLanguage": isFr ? "fr-FR" : "en-US",
    },
    {
      "@type": "FAQPage",
      "@id": `${canonical}#faq`,
      "mainEntity": c.faq.map((f) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": isFr ? "Accueil" : "Home", "item": homeUrl },
        { "@type": "ListItem", "position": 2, "name": c.name, "item": canonical },
      ],
    },
  ],
};
---

<main id="main-content" class="bg-[var(--color-bg)] text-[var(--color-ink)]">

  {/* ========== HERO ========== */}
  <section class="relative px-4 pt-32 pb-16 sm:px-6 sm:pt-40 sm:pb-20 md:px-12 md:pt-48 md:pb-24">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <p class="font-mono mb-4 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
        <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
        {c.eyebrow}
      </p>
      <h1 class="font-display text-[clamp(40px,8vw,140px)] uppercase leading-[0.92] tracking-[-0.04em] text-[var(--color-ink)]">
        {c.h1Lines.map((line, i) => (
          <span class:list={["block", i > 0 && "opacity-70"]}>{line}</span>
        ))}
      </h1>
      <p class="font-serif-italic mt-8 max-w-[46ch] text-[clamp(18px,2vw,28px)] leading-tight text-[var(--color-ink)]">
        {c.lead}
      </p>
      <p class="font-mono mt-8 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
        {labels.availability}
      </p>
    </div>
  </section>

  {/* ========== INTRO PROSE ========== */}
  <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
    <div class="mx-auto w-full max-w-[68ch]">
      <div class="font-sans space-y-6 text-[clamp(16px,1.3vw,20px)] leading-[1.7] text-[var(--color-ink)]">
        {c.intro.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  {/* ========== INCLUDES ========== */}
  <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <header class="mb-12 sm:mb-16">
        <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          {c.includesTitle}
        </p>
      </header>
      <ul class="grid gap-px overflow-hidden border border-[var(--color-border)] sm:grid-cols-2 lg:grid-cols-3">
        {c.includes.map((item) => (
          <li class="flex items-start gap-3 bg-[var(--color-bg)] p-6 text-[clamp(15px,1.1vw,17px)] leading-snug text-[var(--color-ink)] sm:p-8">
            <span aria-hidden="true" class="font-mono shrink-0 pt-0.5 text-[12px] text-[var(--color-accent)]">→</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ========== METHOD ========== */}
  <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <header class="mb-16 sm:mb-20">
        <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          {c.methodTitle}
        </p>
      </header>
      <ol class="flex flex-col gap-12 sm:gap-16">
        {c.method.map((step) => (
          <li class="grid grid-cols-1 gap-4 border-t border-[var(--color-border)] pt-8 sm:grid-cols-[140px_1fr] sm:gap-12">
            <span class="font-display text-[clamp(48px,5vw,80px)] leading-none tracking-[-0.04em] text-[var(--color-accent)]">
              {step.n}
            </span>
            <div>
              <h2 class="font-sans text-[clamp(20px,2.2vw,28px)] font-medium tracking-normal text-[var(--color-ink)]">
                {step.title}
              </h2>
              <p class="mt-3 max-w-[60ch] text-[clamp(15px,1.2vw,17px)] leading-[1.65] text-[var(--color-ink-muted)]">
                {step.body}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* ========== PROOF — featured case studies ========== */}
  <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <header class="mb-12 sm:mb-16">
        <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          {c.proofTitle}
        </p>
      </header>
      <div class="grid gap-6 sm:grid-cols-3 sm:gap-5">
        {proof.map((p) => (
          <a href={caseStudyPath(p.slug, lang)} class="group flex flex-col no-underline">
            <div class="relative aspect-[4/3] overflow-hidden bg-[var(--color-border)]">
              <img
                src={p.image}
                alt={`${p.title} — ${p.tag}`}
                width="500"
                height="375"
                loading="lazy"
                class="absolute inset-0 block h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
              />
            </div>
            <h3 class="font-sans mt-3 text-[clamp(15px,1.1vw,18px)] font-medium tracking-normal text-[var(--color-ink)]">
              {p.title}
            </h3>
            <span class="font-mono mt-1 text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
              {p.tag}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ========== FAQ ========== */}
  <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <header class="mb-12 sm:mb-16">
        <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          {c.faqTitle}
        </p>
      </header>
      <dl class="flex flex-col">
        {c.faq.map((f) => (
          <div class="grid grid-cols-1 gap-3 border-t border-[var(--color-border)] py-8 sm:grid-cols-[1fr_1.3fr] sm:gap-12">
            <dt class="font-sans text-[clamp(17px,1.6vw,24px)] font-medium leading-snug text-[var(--color-ink)]">
              {f.q}
            </dt>
            <dd class="max-w-[60ch] text-[clamp(15px,1.2vw,17px)] leading-[1.65] text-[var(--color-ink-muted)]">
              {f.a}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {/* ========== RELATED SERVICES ========== */}
  <section class="relative bg-[var(--color-bg)] px-4 pt-20 pb-4 sm:px-6 sm:pt-28 md:px-12 md:pt-32">
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <p class="font-mono mb-6 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
        {c.relatedTitle}
      </p>
      <div class="grid grid-cols-1 gap-px overflow-hidden border border-[var(--color-border)] sm:grid-cols-2">
        {sp.related.map((r) => (
          <a
            href={r.path}
            class="group flex items-center justify-between gap-4 bg-[var(--color-bg)] p-6 no-underline transition-colors hover:bg-[var(--color-border)]/40 sm:p-8"
          >
            <span class="font-display text-[clamp(20px,2.2vw,32px)] uppercase leading-[1] tracking-[-0.03em] text-[var(--color-ink)]">
              {r.name}
            </span>
            <span aria-hidden="true" class="font-mono text-[var(--color-accent)]">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Contact — consistent close. */}
  <CTA lang={lang} />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</main>
