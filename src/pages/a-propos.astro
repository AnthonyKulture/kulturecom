---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import CTA from "~/components/CTA.astro";

const lang = "fr" as const;

const stack = [
  {
    label: "01",
    title: "Design",
    items: [
      "Figma + Design tokens",
      "Direction artistique éditoriale",
      "Identité visuelle + brand systems",
      "Typographie + grilles",
    ],
  },
  {
    label: "02",
    title: "Code",
    items: [
      "Astro, React, TypeScript",
      "Tailwind CSS v4",
      "GSAP + ScrollTrigger",
      "Headless CMS (Sanity, Storyblok)",
      "Vercel, Cloudflare",
    ],
  },
  {
    label: "03",
    title: "SEO",
    items: [
      "Search Console + Ahrefs",
      "Audit technique + Core Web Vitals",
      "Schema.org + AI search readiness",
      "Content cluster + on-page",
      "GA4 + tracking server-side",
    ],
  },
];

const process = [
  {
    n: "01",
    title: "Audit",
    body: "Une semaine pour comprendre votre marché, votre site actuel, vos signaux SEO et votre vraie cible. Pas de devis sans cette étape.",
  },
  {
    n: "02",
    title: "Stratégie",
    body: "Cadrage écrit : positionnement, hiérarchie des pages, mots-clés ciblés, KPIs à 3/6/12 mois. Vous validez avant qu'une ligne soit dessinée.",
  },
  {
    n: "03",
    title: "Design",
    body: "Maquettes haute-fidélité Figma. Itérations rapides sur Loom. Pas de wireframes basse-fi qui retardent la décision.",
  },
  {
    n: "04",
    title: "Build",
    body: "Astro + React, performance-first. Lighthouse ≥ 95, accessibilité WCAG AA. Tout le code vous appartient à la livraison.",
  },
  {
    n: "05",
    title: "Ship & mesure",
    body: "Mise en ligne, Search Console branchée, tracking validé. Suivi 30 jours inclus. Optimisation continue en option (retainer mensuel).",
  },
];

const refuse = [
  "Templates Webflow recyclés vendus comme du sur-mesure.",
  "SEO black-hat, link farms, content scraping.",
  "« Refonte » sans audit préalable.",
  "Sites lourds qui chargent en 4 secondes.",
  "Devis chiffrés sans brief écrit.",
  "Engagement long sans phase d'essai.",
];
---

<BaseLayout lang={lang} pathname="/a-propos/">
  <Nav lang={lang} altLang="en" altLangPath="/en/about/" />
  <main id="main-content" class="bg-[var(--color-bg)] text-[var(--color-ink)]">

    <!-- ========== INTRO / HERO ========== -->
    <section class="relative px-4 pt-32 pb-20 sm:px-6 sm:pt-40 sm:pb-28 md:px-12 md:pt-48 md:pb-32">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <p class="font-mono mb-4 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          À propos
        </p>
        <h1 class="font-display text-[clamp(40px,9vw,160px)] uppercase leading-[0.92] tracking-[-0.04em] text-[var(--color-ink)]">
          <span class="block">Anthony Profit,</span>
          <span class="block opacity-70">freelance depuis 2018.</span>
        </h1>
        <p class="font-serif-italic mt-8 max-w-[40ch] text-[clamp(18px,2vw,28px)] leading-tight text-[var(--color-ink)]">
          Web design + code + SEO. Un seul interlocuteur. Huit ans à transformer des marques invisibles en marques cherchées.
        </p>

        <!-- Meta strip -->
        <dl class="font-mono mt-12 grid grid-cols-2 gap-6 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)] sm:grid-cols-4 sm:gap-10">
          <div>
            <dt class="opacity-60">Disponibilité</dt>
            <dd class="mt-1 text-[var(--color-ink)]">Q4 2026</dd>
          </div>
          <div>
            <dt class="opacity-60">Localisation</dt>
            <dd class="mt-1 text-[var(--color-ink)]">Paris / Remote</dd>
          </div>
          <div>
            <dt class="opacity-60">Délai réponse</dt>
            <dd class="mt-1 text-[var(--color-ink)]">48 h ouvrées</dd>
          </div>
          <div>
            <dt class="opacity-60">Projets/an</dt>
            <dd class="mt-1 text-[var(--color-ink)]">8 max</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ========== STORY (dark band) ========== -->
    <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[68ch]">
        <p class="font-mono mb-6 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          Parcours
        </p>
        <div class="font-sans space-y-6 text-[clamp(16px,1.3vw,20px)] leading-[1.7] text-[var(--color-ink)]">
          <p>
            J'ai commencé en agence digitale, j'ai vu trop de projets sortir cassés parce que trois équipes (brand, dev, SEO) se passaient des fichiers sans jamais se parler. En 2018, j'ai décidé de faire les trois moi-même. Pas pour être polyvalent — pour <em class="font-serif-italic">supprimer les friction points</em> entre les disciplines.
          </p>
          <p>
            Depuis, je travaille en solo avec un objectif simple : <strong class="font-medium text-[var(--color-ink)]">votre marque doit être trouvée, comprise, et préférée</strong>. La forme (design), la mécanique (code) et la visibilité (SEO) sont trois faces d'un même problème. Je les traite ensemble parce que les séparer coûte plus cher au client qu'à moi.
          </p>
          <p>
            Je travaille avec des <strong class="font-medium text-[var(--color-ink)]">PME en croissance, des marques B2B techniques, et des fondateurs qui prennent l'image au sérieux</strong>. Je ne prends pas de projets « refonte cosmétique » sans repenser la structure SEO. Je ne fais pas de mission de moins de 8 semaines. Je n'ai jamais utilisé un template Webflow et je n'ai pas l'intention de commencer.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== STACK (3 columns) ========== -->
    <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-12 sm:mb-16">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            Stack
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Trois axes, <br />outils alignés.
          </h2>
        </header>

        <div class="grid gap-10 md:grid-cols-3 md:gap-12">
          {
            stack.map((s) => (
              <article class="border-t border-[var(--color-border)] pt-6">
                <span class="font-mono block text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
                  {s.label}
                </span>
                <h3 class="font-sans mt-2 text-[clamp(22px,2.5vw,32px)] font-medium tracking-normal text-[var(--color-ink)]">
                  {s.title}
                </h3>
                <ul class="mt-6 space-y-2 text-[clamp(14px,1.1vw,16px)] text-[var(--color-ink-muted)]">
                  {s.items.map((item) => (
                    <li class="flex gap-2">
                      <span aria-hidden="true" class="font-mono shrink-0 pt-0.5 text-[10px] text-[var(--color-accent)]">→</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ========== PROCESS (numbered narrative) ========== -->
    <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-16 sm:mb-20">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            Process
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Cinq étapes, <br />zéro surprise.
          </h2>
        </header>

        <ol class="flex flex-col gap-12 sm:gap-16">
          {
            process.map((step) => (
              <li class="grid grid-cols-1 gap-4 border-t border-[var(--color-border)] pt-8 sm:grid-cols-[140px_1fr] sm:gap-12">
                <span class="font-display text-[clamp(48px,5vw,80px)] leading-none tracking-[-0.04em] text-[var(--color-accent)]">
                  {step.n}
                </span>
                <div>
                  <h3 class="font-sans text-[clamp(20px,2.2vw,28px)] font-medium tracking-normal text-[var(--color-ink)]">
                    {step.title}
                  </h3>
                  <p class="mt-3 max-w-[60ch] text-[clamp(15px,1.2vw,17px)] leading-[1.65] text-[var(--color-ink-muted)]">
                    {step.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ========== REFUS / ANTI-CREDO ========== -->
    <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-12 sm:mb-16">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            Ce que je refuse
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Six lignes <br />à ne pas franchir.
          </h2>
        </header>

        <ul class="font-display flex flex-col">
          {
            refuse.map((line, i) => (
              <li class="flex items-start gap-4 border-t border-[var(--color-border)] py-6 text-[clamp(20px,2.5vw,40px)] uppercase leading-[1.05] text-[var(--color-ink)] sm:gap-8 sm:py-8">
                <span class="font-mono shrink-0 pt-2 text-[12px] tracking-[0.18em] text-[var(--color-ink-subtle)]">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span>{line}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {/* Contact — the same section as the home / contact page, for a consistent
        text + visual treatment across the site (replaces the old mini-CTA). */}
    <CTA lang={lang} />

  </main>
</BaseLayout>
