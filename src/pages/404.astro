---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import type { Lang } from "~/i18n/ui";

const lang: Lang = "fr";
---

<BaseLayout lang={lang} pathname="/404">
  <Nav lang={lang} altLang="en" altLangPath="/en/" />
  <main
    id="main-content"
    class="relative flex min-h-[100dvh] flex-col items-start justify-center bg-[var(--color-bg)] px-4 py-24 text-[var(--color-ink)] sm:px-6 md:px-12"
  >
    <div class="mx-auto w-full max-w-[var(--container-wide)]">
      <p
        class="font-mono mb-8 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]"
      >
        <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
        Erreur · 404
      </p>

      <h1
        class="font-display text-[clamp(80px,18vw,260px)] uppercase leading-[0.85] tracking-[-0.04em] text-[var(--color-ink)]"
      >
        404
      </h1>

      <p
        class="font-serif-italic mt-6 max-w-[44ch] text-[clamp(20px,3vw,36px)] leading-[1.25] text-[var(--color-ink)] sm:mt-10"
      >
        Page introuvable.
      </p>
      <p
        class="mt-3 max-w-[60ch] text-[clamp(14px,1.2vw,18px)] leading-[1.55] text-[var(--color-ink-muted)] sm:mt-5"
      >
        Le lien est cassé, la page a été déplacée, ou elle n'a jamais existé. Aucun
        souci — voici où repartir.
      </p>

      <ul class="mt-10 flex flex-col gap-2 sm:mt-14 sm:flex-row sm:gap-6">
        <li>
          <a
            href="/"
            class="font-display inline-flex items-center gap-3 bg-[var(--color-ink)] px-6 py-4 text-[clamp(14px,1.2vw,18px)] uppercase text-[var(--color-bg)] no-underline transition-colors duration-200 hover:bg-[var(--color-accent)]"
          >
            Retour à l'accueil
            <span aria-hidden="true">→</span>
          </a>
        </li>
        <li>
          <a
            href="/a-propos/"
            class="font-display inline-flex items-center gap-3 border border-[var(--color-ink)] bg-transparent px-6 py-4 text-[clamp(14px,1.2vw,18px)] uppercase text-[var(--color-ink)] no-underline transition-colors duration-200 hover:bg-[var(--color-ink)] hover:text-[var(--color-bg)]"
          >
            À propos
            <span aria-hidden="true">→</span>
          </a>
        </li>
      </ul>
    </div>
  </main>
</BaseLayout>
