---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Projects from "~/components/Projects.astro";
import ProjectsMobile from "~/components/ProjectsMobile.astro";

const lang = "en" as const;
---

<BaseLayout lang={lang} pathname="/en/work/" altPath="/projets/">
  <Nav lang={lang} altLang="fr" altLangPath="/projets/" />
  <main id="main-content" class="bg-[var(--color-bg)] text-[var(--color-ink)]">

    {/* ========== PAGE HERO ========== */}
    <section class="relative px-4 pt-32 pb-12 sm:px-6 sm:pt-40 sm:pb-16 md:px-12 md:pt-48 md:pb-20">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <p class="font-mono mb-4 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          Work
        </p>
        <h1 class="font-display text-[clamp(40px,9vw,160px)] uppercase leading-[0.92] tracking-[-0.04em] text-[var(--color-ink)]">
          <span class="block">Proof,</span>
          <span class="block opacity-70">not promises.</span>
        </h1>
        <p class="font-serif-italic mt-8 max-w-[44ch] text-[clamp(18px,2vw,28px)] leading-tight text-[var(--color-ink)]">
          Five projects taken end to end — design, code and SEO, from the first audit to ranking.
        </p>
      </div>
    </section>

    {/* ========== PROJECTS — the selection removed from the homepage screen-stack.
        Desktop = horizontal 5-card grid (Projects.astro, min-h-100dvh). Mobile =
        stacked detail list with fade-up reveal (ProjectsMobile.astro). One renders
        per breakpoint via hidden/sm:hidden, matching the homepage's split. ========== */}
    <div class="hidden sm:block">
      <Projects lang={lang} />
    </div>
    <div class="sm:hidden">
      <ProjectsMobile lang={lang} />
    </div>

  </main>
</BaseLayout>
