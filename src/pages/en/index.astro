---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Hero from "~/components/Hero.astro";
import About from "~/components/About.astro";
import AboutPortrait from "~/components/AboutPortrait.astro";
import CinematicScroll from "~/components/CinematicScroll.astro";
import AboutChapter from "~/components/AboutChapter.astro";
import CTA from "~/components/CTA.astro";
import type { Lang } from "~/i18n/ui";

const lang: Lang = "en";
---

<BaseLayout lang={lang} pathname="/en/">
  <Nav lang={lang} altLang="fr" altLangPath="/" />
  <main id="main-content">
    {/* Hero — wrapped in a pinned container that drives a scroll-based
        wipe transition (see src/lib/hero-transition.ts). */}
    {/* `min-h-[100dvh]` on the PIN element (not the Hero <section> inside it)
        keeps the pin/seam geometry locked to the live viewport so About's DOM
        offset always equals the pin distance — no seam gap on URL-bar collapse.
        The Hero <section> is `min-h-[100svh]` (stable) so the centered H1 does
        NOT re-center downward when dvh grows. See src/pages/index.astro. */}
    <div data-hero-pin class="relative min-h-[100dvh]">
      <Hero lang={lang} />
      {/* Departure backdrop — opaque ink layer BEHIND the transition image
          (z-20, between the hero text z-10 and the image z-30). Faded 0→1 by
          hero-transition.ts just before the image lifts off. As the image
          rises + blurs, anything that peeks below its bottom edge (the blur
          halo, or a gap if the scrub-driven image desyncs from About's native
          scroll on a fast mobile fling) lands on THIS ink instead of the cream
          body bg — so the seam reads dark→dark (organic), never flashing white.
          It's `absolute` (not fixed), so it scrolls away with the pinned hero
          on release and can't persist over the cream Contact section below. */}
      <div
        data-hero-transition-backdrop
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 z-20 bg-[#0b0b0b]"
        style="opacity: 0;"
      >
      </div>
      <img
        data-hero-transition-image
        src="/hero-slides/hero-image.jpeg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none fixed inset-0 z-30 h-full w-full object-cover"
        style="will-change: transform, clip-path; clip-path: inset(50% 0 50% 0);"
      />
    </div>

    {/* About — `data-about-wrapper` hook for hero-transition.ts +50vh
        translateY initial state. Arrives at viewport top at pin end. */}
    <div data-about-wrapper class="relative" style="z-index: 60;">
      {/* Seam feather (couture): additive black→transparent gradient just
          above the panel's top edge, painted over the rising blurred photo
          so it dissolves into the dark with no hard line. Additive black
          (not a transparent mask), so it can never expose the cream bg when
          the image/panel overlap shrinks on fast scroll. Rides with the
          wrapper, always at the seam. */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 h-[16vh] -translate-y-full bg-gradient-to-t from-[#0b0b0b] to-transparent"
      >
      </div>
      <About lang={lang} />
      {/* Bottom feather — mirror of the top seam: black→transparent gradient just
          below the panel's bottom edge, over the fixed cinematic stage behind it, so
          the About dissolves softly into the emerging cylinder. Rides with the wrapper. */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 bottom-0 h-[24vh] translate-y-full bg-gradient-to-b from-[#0b0b0b] to-transparent"
      >
      </div>
    </div>

    {/* Fixed portrait for the About manifesto — sibling of the wrapper (its
        translateY transform would break position:fixed inside). Held on the
        side (desktop) / top banner (mobile); faded in/out by about-portrait.ts. */}
    <AboutPortrait />

    {/* Cinematic cylinder — full-viewport WebGL (OGL) section inserted AFTER the
        3 About service teasers and BEFORE the pinned screen-stack. Pins for a
        scrubbed camera fly-through of the project images, then releases into the
        stack below. Lazy-booted + rAF-gated (src/lib/cinematic-scroll.ts). */}
    <CinematicScroll lang={lang} />

    {/* Calm "Promesse" photo — the cross-dissolve target. A FIXED full-viewport
        layer at z-index:-1 (a sibling of the cinematic stage, sitting ABOVE it in
        the same negative layer). cinematic-scroll.ts fades it in (opacity 0→1) while
        the cylinder slows + dims, so the spinning cylinder CROSS-DISSOLVES into this
        still photo IN PLACE — no black, no curtain, nothing sliding. It stays put
        (fixed) while the transparent screen-stack rises over it; the built-in scrim
        darkens it just enough for the cream Promesse text. Shows only through the
        transparent About 2 window (z:-1 is occluded by every opaque section). */}
    <div
      data-promesse-photo
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 overflow-hidden opacity-0"
      style="z-index: -1; will-change: opacity;"
    >
      {/* Tall image (200% of the viewport) so the vertical PARALLAX can travel from the top of
          the photo to the bottom as the message is read (about-scroll.ts drifts its yPercent). */}
      <img
        data-promesse-photo-img
        src="/about/kulturecom-webdesign.webp"
        alt=""
        width="2400"
        height="3600"
        class="absolute inset-x-0 top-0 h-[200%] w-full object-cover"
        style="will-change: transform;"
      />
      {/* Soft gradient scrim for text legibility — part of THIS layer, so it fades IN with the
          photo (never "appears" as a separate dark filter), and a gradient (not a flat fill) so
          most of the image stays clean. Static: it does NOT ride the parallax. */}
      <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/15 to-transparent"></div>
    </div>

    {/* Pinned screen-stack — About 2 → Contact. TRANSPARENT now: the calm photo above
        is the background (shown through this stack), and the cylinder cross-dissolves
        into it before this stack covers — so there's no curtain and no dark backdrop.
        About 2 is just the Promesse text, which WRITES IN over the held photo once the
        stack pins; then the Contact layer reveals with the bottom-right circle clip-path.
        Driven by src/lib/about-scroll.ts. (Services + Projects moved to standalone pages.) */}
    <div
      data-screen-stack
      class="relative isolate h-[100lvh] overflow-hidden"
    >
      <div
        data-screen-layer="about2"
        class="absolute inset-0 z-10"
      >
        <AboutChapter lang={lang} chapterKey="about2" />
      </div>
      {/* Contact — revealed over About 2 with the circle clip-path. CTA is responsive
          and has an opaque cream background, so one layer covers desktop and mobile. */}
      <div
        data-screen-layer="cta"
        class="absolute inset-0 z-30"
        style="clip-path: circle(0% at 100% 100%);"
      >
        <CTA lang={lang} />
      </div>
    </div>
  </main>

  <script>
    import { initSmoothScroll } from "~/lib/smooth-scroll";
    import { initAboutScroll } from "~/lib/about-scroll";
    import { initAboutReveal } from "~/lib/about-reveal";
    import { initAboutPortrait } from "~/lib/about-portrait";
    import { initCinematicScroll } from "~/lib/cinematic-scroll";
    import { initHeroTransition } from "~/lib/hero-transition";
    initSmoothScroll();
    initAboutScroll();
    initAboutReveal();
    initAboutPortrait();
    initCinematicScroll();
    initHeroTransition();
  </script>
</BaseLayout>
