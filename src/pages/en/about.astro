---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import CTA from "~/components/CTA.astro";

const lang = "en" as const;

const stack = [
  {
    label: "01",
    title: "Design",
    items: [
      "Figma + Design tokens",
      "Editorial art direction",
      "Visual identity + brand systems",
      "Typography + grids",
    ],
  },
  {
    label: "02",
    title: "Code",
    items: [
      "Astro, React, TypeScript",
      "Tailwind CSS v4",
      "GSAP + ScrollTrigger",
      "Headless CMS (Sanity, Storyblok)",
      "Vercel, Cloudflare",
    ],
  },
  {
    label: "03",
    title: "SEO",
    items: [
      "Search Console + Ahrefs",
      "Technical audit + Core Web Vitals",
      "Schema.org + AI search readiness",
      "Content cluster + on-page",
      "GA4 + server-side tracking",
    ],
  },
];

const process = [
  {
    n: "01",
    title: "Audit",
    body: "One week to understand your market, your current site, your SEO signals and your real target. No quote without this step.",
  },
  {
    n: "02",
    title: "Strategy",
    body: "Written brief: positioning, page hierarchy, target keywords, KPIs at 3/6/12 months. You sign off before a single line is drawn.",
  },
  {
    n: "03",
    title: "Design",
    body: "High-fidelity Figma mockups. Fast Loom iterations. No low-fi wireframes that delay the decision.",
  },
  {
    n: "04",
    title: "Build",
    body: "Astro + React, performance-first. Lighthouse ≥ 95, WCAG AA accessibility. All code is yours on delivery.",
  },
  {
    n: "05",
    title: "Ship & measure",
    body: "Go live, Search Console wired, tracking validated. 30 days of follow-up included. Continuous optimisation optional (monthly retainer).",
  },
];

const refuse = [
  "Recycled Webflow templates sold as bespoke.",
  "Black-hat SEO, link farms, content scraping.",
  "« Redesigns » without a prior audit.",
  "Bloated sites that load in 4 seconds.",
  "Fixed quotes without a written brief.",
  "Long-term retainers without a trial phase.",
];
---

<BaseLayout lang={lang} pathname="/en/about/">
  <Nav lang={lang} altLang="fr" altLangPath="/a-propos/" />
  <main id="main-content" class="bg-[var(--color-bg)] text-[var(--color-ink)]">

    <!-- ========== INTRO / HERO ========== -->
    <section class="relative px-4 pt-32 pb-20 sm:px-6 sm:pt-40 sm:pb-28 md:px-12 md:pt-48 md:pb-32">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <p class="font-mono mb-4 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          About
        </p>
        <h1 class="font-display text-[clamp(40px,9vw,160px)] uppercase leading-[0.92] tracking-[-0.04em] text-[var(--color-ink)]">
          <span class="block">Anthony Profit,</span>
          <span class="block opacity-70">freelance since 2018.</span>
        </h1>
        <p class="font-serif-italic mt-8 max-w-[40ch] text-[clamp(18px,2vw,28px)] leading-tight text-[var(--color-ink)]">
          Web design + code + SEO. One point of contact. Eight years turning invisible brands into sought-after ones.
        </p>

        <dl class="font-mono mt-12 grid grid-cols-2 gap-6 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)] sm:grid-cols-4 sm:gap-10">
          <div>
            <dt class="opacity-60">Availability</dt>
            <dd class="mt-1 text-[var(--color-ink)]">Q4 2026</dd>
          </div>
          <div>
            <dt class="opacity-60">Location</dt>
            <dd class="mt-1 text-[var(--color-ink)]">Paris / Remote</dd>
          </div>
          <div>
            <dt class="opacity-60">Reply within</dt>
            <dd class="mt-1 text-[var(--color-ink)]">48 working hrs</dd>
          </div>
          <div>
            <dt class="opacity-60">Projects/year</dt>
            <dd class="mt-1 text-[var(--color-ink)]">8 max</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ========== STORY (dark band) ========== -->
    <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[68ch]">
        <p class="font-mono mb-6 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          Background
        </p>
        <div class="font-sans space-y-6 text-[clamp(16px,1.3vw,20px)] leading-[1.7] text-[var(--color-ink)]">
          <p>
            I started in a digital agency, where I watched too many projects ship broken because three teams (brand, dev, SEO) passed files around without ever talking. In 2018, I decided to do all three myself. Not to be a generalist — to <em class="font-serif-italic">remove the friction points</em> between disciplines.
          </p>
          <p>
            Since then, I work solo with a single goal: <strong class="font-medium text-[var(--color-ink)]">your brand should be found, understood, and preferred</strong>. Form (design), mechanics (code), and visibility (SEO) are three faces of the same problem. I handle them together because separating them costs the client more than it costs me.
          </p>
          <p>
            I work with <strong class="font-medium text-[var(--color-ink)]">growing SMBs, technical B2B brands, and founders who take image seriously</strong>. I don't take « cosmetic redesign » jobs without rethinking SEO structure. I don't do engagements under 8 weeks. I have never used a Webflow template and I don't plan to start.
          </p>
        </div>
      </div>
    </section>

    <!-- ========== STACK ========== -->
    <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-12 sm:mb-16">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            Stack
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Three crafts, <br />aligned tools.
          </h2>
        </header>

        <div class="grid gap-10 md:grid-cols-3 md:gap-12">
          {
            stack.map((s) => (
              <article class="border-t border-[var(--color-border)] pt-6">
                <span class="font-mono block text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
                  {s.label}
                </span>
                <h3 class="font-sans mt-2 text-[clamp(22px,2.5vw,32px)] font-medium tracking-normal text-[var(--color-ink)]">
                  {s.title}
                </h3>
                <ul class="mt-6 space-y-2 text-[clamp(14px,1.1vw,16px)] text-[var(--color-ink-muted)]">
                  {s.items.map((item) => (
                    <li class="flex gap-2">
                      <span aria-hidden="true" class="font-mono shrink-0 pt-0.5 text-[10px] text-[var(--color-accent)]">→</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ========== PROCESS ========== -->
    <section data-surface="dark" class="relative bg-[var(--color-bg)] text-[var(--color-ink)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-16 sm:mb-20">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            Process
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Five steps, <br />zero surprises.
          </h2>
        </header>

        <ol class="flex flex-col gap-12 sm:gap-16">
          {
            process.map((step) => (
              <li class="grid grid-cols-1 gap-4 border-t border-[var(--color-border)] pt-8 sm:grid-cols-[140px_1fr] sm:gap-12">
                <span class="font-display text-[clamp(48px,5vw,80px)] leading-none tracking-[-0.04em] text-[var(--color-accent)]">
                  {step.n}
                </span>
                <div>
                  <h3 class="font-sans text-[clamp(20px,2.2vw,28px)] font-medium tracking-normal text-[var(--color-ink)]">
                    {step.title}
                  </h3>
                  <p class="mt-3 max-w-[60ch] text-[clamp(15px,1.2vw,17px)] leading-[1.65] text-[var(--color-ink-muted)]">
                    {step.body}
                  </p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <!-- ========== REFUSE / ANTI-CREDO ========== -->
    <section class="relative bg-[var(--color-bg)] px-4 py-24 sm:px-6 sm:py-32 md:px-12 md:py-40">
      <div class="mx-auto w-full max-w-[var(--container-wide)]">
        <header class="mb-12 sm:mb-16">
          <p class="font-mono mb-3 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
            <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
            What I won't do
          </p>
          <h2 class="font-display text-[clamp(28px,5vw,72px)] uppercase leading-[0.95] tracking-[-0.04em] text-[var(--color-ink)]">
            Six lines <br />I won't cross.
          </h2>
        </header>

        <ul class="font-display flex flex-col">
          {
            refuse.map((line, i) => (
              <li class="flex items-start gap-4 border-t border-[var(--color-border)] py-6 text-[clamp(20px,2.5vw,40px)] uppercase leading-[1.05] text-[var(--color-ink)] sm:gap-8 sm:py-8">
                <span class="font-mono shrink-0 pt-2 text-[12px] tracking-[0.18em] text-[var(--color-ink-subtle)]">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span>{line}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    {/* Contact — the same section as the home / contact page, for a consistent
        text + visual treatment across the site (replaces the old mini-CTA). */}
    <CTA lang={lang} />

  </main>
</BaseLayout>
