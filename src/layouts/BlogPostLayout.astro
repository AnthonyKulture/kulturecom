---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import type { Lang } from "~/i18n/ui";
import type { Post } from "~/lib/blog";
import { postPath, tagPath, slugifyTag, formatDate } from "~/lib/blog";
import type { MarkdownHeading } from "astro";

interface Props {
  post: Post;
  headings: MarkdownHeading[];
  readingTime: number;
  related: Post[];
  lang: Lang;
  pathname: string;
  /** Counterpart-post path for hreflang, or null when untranslated. */
  hreflangAltPath: string | null;
  /** Where the language switcher points (counterpart post or other blog index). */
  navAltLangPath: string;
}

const {
  post,
  headings,
  readingTime,
  related,
  lang,
  pathname,
  hreflangAltPath,
  navAltLangPath,
} = Astro.props;

const isFr = lang === "fr";
const d = post.data;
const altLang: Lang = isFr ? "en" : "fr";

const pageTitle = `${d.metaTitle ?? d.title} | Anthony Profit`;

// ── Absolute URLs + entity ids (cross-reference BaseLayout's Person/WebSite) ──
const site = Astro.site;
const canonical = new URL(pathname, site).toString();
const homeUrl = new URL(isFr ? "/" : "/en/", site).toString();
const blogUrl = new URL(isFr ? "/blog/" : "/en/blog/", site).toString();
const ogImage = new URL("/og.png", site).toString();
const imageUrl = d.cover ? new URL(d.cover, site).toString() : ogImage;
const personId = `${site}#person`;
const websiteId = `${site}#website`;
const orgId = `${site}#org`;

// Word count (build-time) — a quality/depth signal for AI citation weighting.
const wordCount = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;

const labels = isFr
  ? {
      home: "Accueil",
      blog: "Journal",
      toc: "Sommaire",
      read: `${readingTime} min de lecture`,
      updated: "Mis à jour le",
      by: "Par",
      tags: "Thèmes",
      related: "À lire ensuite",
      ctaTitle: "Un projet en tête ?",
      ctaLead:
        "Site sur-mesure, SEO/GEO ou refonte — parlons de ce que vous voulez accomplir.",
      ctaBtn: "Discutons",
      contactHref: "/contact/",
    }
  : {
      home: "Home",
      blog: "Journal",
      toc: "Contents",
      read: `${readingTime} min read`,
      updated: "Updated",
      by: "By",
      tags: "Topics",
      related: "Read next",
      ctaTitle: "Got a project in mind?",
      ctaLead:
        "Custom site, SEO/GEO or a redesign — let's talk about what you want to achieve.",
      ctaBtn: "Let's talk",
      contactHref: "/en/contact/",
    };

// Table of contents from the H2s (only worth showing past a couple).
const toc = headings.filter((h) => h.depth === 2);
const showToc = toc.length >= 3;

// ── Structured data — BlogPosting + BreadcrumbList ───────────────────────────
const blogPosting: Record<string, unknown> = {
  "@type": "BlogPosting",
  "@id": `${canonical}#article`,
  headline: d.title.slice(0, 110),
  description: d.description,
  datePublished: d.pubDate.toISOString(),
  dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
  author: { "@type": "Person", "@id": personId, name: d.author, url: homeUrl },
  publisher: { "@id": orgId },
  image: imageUrl,
  wordCount,
  inLanguage: isFr ? "fr-FR" : "en-US",
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  isPartOf: { "@id": websiteId },
  url: canonical,
};
if (d.keywords.length) blogPosting.keywords = d.keywords.join(", ");

const breadcrumb = {
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: labels.home, item: homeUrl },
    { "@type": "ListItem", position: 2, name: labels.blog, item: blogUrl },
    { "@type": "ListItem", position: 3, name: d.title, item: canonical },
  ],
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [blogPosting, breadcrumb],
};

const blogHref = isFr ? "/blog/" : "/en/blog/";
const updatedStr = d.updatedDate ? formatDate(d.updatedDate, lang) : null;
---

<BaseLayout
  lang={lang}
  pathname={pathname}
  title={pageTitle}
  description={d.description}
  altPath={hreflangAltPath}
  ogImage={d.cover}
>
  <Nav lang={lang} altLang={altLang} altLangPath={navAltLangPath} />

  <main
    id="main-content"
    class="bg-[var(--color-bg)] text-[var(--color-ink)] px-4 pt-28 pb-24 sm:px-6 sm:pt-36 md:px-12 md:pt-44"
  >
    <article class="mx-auto w-full max-w-[72ch]">
      {/* Breadcrumb */}
      <nav
        aria-label={isFr ? "Fil d'Ariane" : "Breadcrumb"}
        class="font-mono mb-8 flex flex-wrap items-center gap-2 text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-subtle)]"
      >
        <a href={isFr ? "/" : "/en/"} class="no-underline hover:text-[var(--color-ink)]">{labels.home}</a>
        <span aria-hidden="true">/</span>
        <a href={blogHref} class="no-underline hover:text-[var(--color-ink)]">{labels.blog}</a>
      </nav>

      {/* Header */}
      <header class="mb-10 sm:mb-12">
        <p
          class="font-mono mb-5 inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]"
        >
          <span class="inline-block h-px w-6 bg-[var(--color-accent)]"></span>
          {d.tags[0] ?? labels.blog}
        </p>
        <h1
          class="font-display text-[clamp(30px,5vw,60px)] uppercase leading-[0.98] tracking-[-0.04em] text-[var(--color-ink)]"
        >
          {d.title}
        </h1>
        <p
          class="font-serif-italic mt-6 max-w-[54ch] text-[clamp(18px,2vw,26px)] leading-tight text-[var(--color-ink-muted)]"
        >
          {d.description}
        </p>
        <div
          class="font-mono mt-7 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] uppercase tracking-[0.16em] text-[var(--color-ink-subtle)]"
        >
          <time datetime={d.pubDate.toISOString()}>{formatDate(d.pubDate, lang)}</time>
          <span aria-hidden="true">·</span>
          <span>{labels.read}</span>
          <span aria-hidden="true">·</span>
          <span>{labels.by} {d.author}</span>
          {
            updatedStr && (
              <>
                <span aria-hidden="true">·</span>
                <span>{labels.updated} {updatedStr}</span>
              </>
            )
          }
        </div>
      </header>

      {/* Table of contents */}
      {
        showToc && (
          <nav
            aria-label={labels.toc}
            class="mb-12 border-y border-[var(--color-border)] py-6"
          >
            <p class="font-mono mb-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-muted)]">
              {labels.toc}
            </p>
            <ol class="flex flex-col gap-1.5">
              {toc.map((h, i) => (
                <li class="flex gap-3 text-[14px] leading-snug">
                  <span class="font-mono text-[var(--color-ink-subtle)]">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <a
                    href={`#${h.slug}`}
                    class="text-[var(--color-ink-muted)] no-underline hover:text-[var(--color-ink)] hover:underline underline-offset-4"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }

      {/* Article body (MDX) */}
      <div class="prose-blog">
        <slot />
      </div>

      {/* Tags */}
      {
        d.tags.length > 0 && (
          <div class="mt-14 border-t border-[var(--color-border)] pt-6">
            <p class="font-mono mb-3 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
              {labels.tags}
            </p>
            <ul class="flex flex-wrap gap-2">
              {d.tags.map((t) => (
                <li>
                  <a
                    href={tagPath(lang, slugifyTag(t))}
                    class="font-mono inline-block border border-[var(--color-border)] px-3 py-1.5 text-[11px] uppercase tracking-[0.14em] text-[var(--color-ink-muted)] no-underline transition-colors hover:border-[var(--color-ink)] hover:text-[var(--color-ink)]"
                  >
                    {t}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {/* End CTA */}
      <aside
        data-surface="dark"
        class="mt-14 bg-[var(--color-bg)] p-8 text-[var(--color-ink)] sm:p-10"
      >
        <p class="font-display text-[clamp(22px,3vw,34px)] uppercase leading-[1] tracking-[-0.03em]">
          {labels.ctaTitle}
        </p>
        <p class="mt-3 max-w-[46ch] text-[clamp(14px,1.1vw,16px)] leading-[1.6] text-[var(--color-ink-muted)]">
          {labels.ctaLead}
        </p>
        <a
          href={labels.contactHref}
          class="group mt-6 inline-flex items-center gap-3 bg-[var(--color-accent)] px-6 py-3 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-bg)] no-underline transition-opacity duration-200 hover:opacity-90"
        >
          {labels.ctaBtn}
          <span aria-hidden="true" class="transition-transform duration-300 ease-out group-hover:translate-x-1">→</span>
        </a>
      </aside>

      {/* Related */}
      {
        related.length > 0 && (
          <section class="mt-16">
            <p class="font-mono mb-5 text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-subtle)]">
              {labels.related}
            </p>
            <ul class="flex flex-col divide-y divide-[var(--color-border)] border-t border-[var(--color-border)]">
              {related.map((r) => (
                <li>
                  <a
                    href={postPath(r)}
                    class="group flex items-center justify-between gap-4 py-5 no-underline"
                  >
                    <span class="font-sans text-[clamp(16px,1.4vw,20px)] font-medium leading-snug text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
                      {r.data.title}
                    </span>
                    <span aria-hidden="true" class="font-mono shrink-0 text-[var(--color-accent)] transition-transform duration-300 ease-out group-hover:translate-x-1">
                      →
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </article>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>

<style is:global>
  /* === Blog article prose ===
     Long-form reading layer for MDX output. Brand-aligned: display headings,
     serif-italic accents via <em>, mono for code. Headings carry scroll-margin
     so the fixed nav doesn't cover them on TOC anchor jumps. */
  .prose-blog {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.15vw, 18px);
    line-height: 1.75;
    color: var(--color-ink);
  }
  .prose-blog > :first-child {
    margin-top: 0;
  }
  .prose-blog h2 {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-top: 3.5rem;
    margin-bottom: 1.1rem;
    scroll-margin-top: 6rem;
    color: var(--color-ink);
  }
  .prose-blog h3 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(18px, 1.5vw, 22px);
    line-height: 1.25;
    margin-top: 2.25rem;
    margin-bottom: 0.6rem;
    scroll-margin-top: 6rem;
    color: var(--color-ink);
  }
  .prose-blog p {
    margin-bottom: 1.4rem;
  }
  /* Scope link styling to TEXT containers only. A bare `.prose-blog a` rule
     (specificity 0,1,1) outranks the Tailwind `text-[…]` utilities (0,1,0) on
     embedded components, which forced the dark <ServiceCTA> button's label to
     the ink color → black text on its black background. Restricting the rule to
     p/li/blockquote leaves component buttons to their own utility colors. */
  .prose-blog :is(p, li, blockquote) a {
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-accent);
  }
  .prose-blog :is(p, li, blockquote) a:hover {
    color: var(--color-accent);
  }
  .prose-blog strong {
    font-weight: 600;
    color: var(--color-ink);
  }
  .prose-blog em {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05em;
  }
  .prose-blog ul,
  .prose-blog ol {
    margin: 0 0 1.4rem;
    padding-left: 1.4rem;
  }
  .prose-blog ul {
    list-style: disc;
  }
  .prose-blog ol {
    list-style: decimal;
  }
  .prose-blog li {
    margin-bottom: 0.4rem;
  }
  .prose-blog li::marker {
    color: var(--color-accent);
  }
  .prose-blog blockquote {
    margin: 2rem 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--color-accent);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.15em;
    color: var(--color-ink-muted);
  }
  .prose-blog blockquote p {
    margin-bottom: 0;
  }
  .prose-blog hr {
    margin: 3rem 0;
    border: 0;
    border-top: 1px solid var(--color-border);
  }
  .prose-blog code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--color-bg-shade);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
  .prose-blog pre {
    margin: 2rem 0;
    padding: 1.25rem;
    overflow-x: auto;
    background: var(--color-ink);
    color: var(--color-bg);
    font-size: 0.85em;
    line-height: 1.6;
  }
  .prose-blog pre code {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }
  .prose-blog img {
    display: block;
    width: 100%;
    height: auto;
    margin: 2.5rem 0;
  }
  .prose-blog figcaption {
    font-family: var(--font-mono);
    font-size: 0.72em;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-subtle);
    margin-top: -1.75rem;
    margin-bottom: 2.5rem;
  }
</style>
